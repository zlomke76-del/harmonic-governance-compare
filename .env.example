# Preferred on Vercel: use AI Gateway.
# Add this in Vercel Project Settings -> Environment Variables.
VERCEL_AI_GATEWAY_API_KEY=vck_your_vercel_ai_gateway_key
VERCEL_AI_GATEWAY_MODEL=openai/gpt-4.1-mini
VERCEL_AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Optional fallback if you are running locally without Vercel AI Gateway.
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1-mini

# Harmonic / Governance Pack API.
# Harmonic-only lane uses /api/evaluate with { response, consequence_level }.
# Harmonic + Governance lane uses /api/governance-pack with the full primitive packet.
HARMONIC_API_KEY=hs_live_your_key_here
HARMONIC_API_URL=https://www.solace-harmonic.com/api/evaluate
HARMONIC_GOVERNANCE_API_URL=https://www.solace-harmonic.com/api/governance-pack

# Optional lane-specific override if Harmonic-only and Governance Pack use different keys.
HARMONIC_ONLY_API_URL=
HARMONIC_ONLY_API_KEY=
HARMONIC_GOVERNANCE_API_KEY=

# Optional: set to true to make failed Harmonic API calls fail the whole request.
STRICT_GOVERNANCE_API=false

# V35 note: the UI can send a per-run model value.
# Use Vercel AI Gateway for cross-provider model IDs such as anthropic/*, google/*, or meta/*.
# OpenAI fallback supports OpenAI model names only.

# Optional UI flag. Leave false unless Vercel AI Gateway has access to the listed cross-provider model IDs.
# When false, the demo dropdown only shows OpenAI-compatible models so runs do not fail on unsupported routes.
NEXT_PUBLIC_ENABLE_CROSS_PROVIDER_MODELS=false
