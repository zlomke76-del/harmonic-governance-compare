# Required: model provider key for the same LLM used in each lane.
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1-mini

# Optional: Harmonic-only evaluation endpoint.
# Leave blank if you only want prompt-level Harmonic constraints.
HARMONIC_ONLY_API_URL=
HARMONIC_ONLY_API_KEY=

# Required for the Harmonic + Governance lane if you want external evaluation.
# Do NOT commit live keys. Paste your hs_live_* key in .env.local only.
HARMONIC_GOVERNANCE_API_URL=
HARMONIC_GOVERNANCE_API_KEY=hs_live_your_key_here

# Optional: set to true to make failed governance API calls fail the whole request.
STRICT_GOVERNANCE_API=false
