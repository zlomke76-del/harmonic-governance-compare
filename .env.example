# Preferred on Vercel: use AI Gateway.
# Add this in Vercel Project Settings -> Environment Variables.
VERCEL_AI_GATEWAY_API_KEY=vck_your_vercel_ai_gateway_key
VERCEL_AI_GATEWAY_MODEL=openai/gpt-4.1-mini
VERCEL_AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Optional fallback if you are running locally without Vercel AI Gateway.
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1-mini

# Harmonic API.
# HARMONIC_API_URL defaults to https://www.solace-harmonic.com/api/evaluate if omitted.
HARMONIC_API_URL=https://www.solace-harmonic.com/api/evaluate
HARMONIC_API_KEY=hs_live_your_key_here

# Optional lane-specific override if Harmonic-only and Governance use different keys/endpoints.
HARMONIC_ONLY_API_URL=
HARMONIC_ONLY_API_KEY=
HARMONIC_GOVERNANCE_API_URL=
HARMONIC_GOVERNANCE_API_KEY=

# Optional: set to true to make failed Harmonic API calls fail the whole request.
STRICT_GOVERNANCE_API=false
